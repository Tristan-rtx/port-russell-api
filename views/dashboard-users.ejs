<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Utilisateurs — Dashboard</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
<main class="container">
  <nav class="nav">
    <a href="/dashboard">Dashboard</a>
    <a href="/dashboard/catways">Catways</a>
    <a href="/dashboard/reservations">Réservations</a>
    <a href="/dashboard/users">Utilisateurs</a>
    <a href="/api-doc">Doc API</a>
    <a href="/logout">Déconnexion</a>
  </nav>

  <h1>Utilisateurs</h1>

  <h2>Créer un utilisateur</h2>
  <form class="card" method="POST" action="/dashboard/users">
    <label>Username</label>
    <input name="username" required />
    <label>Email</label>
    <input name="email" type="email" required />
    <label>Mot de passe</label>
    <input name="password" type="password" required />
    <button type="submit">Créer</button>
  </form>

  <h2>Liste</h2>
  <table>
    <thead>
      <tr><th>Username</th><th>Email</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.username %></td>
          <td><%= u.email %></td>
          <td>
            <details>
              <summary>Modifier</summary>
              <form method="POST" action="/dashboard/users/<%= u.email %>?_method=PUT">
                <input name="username" value="<%= u.username %>" />
                <input name="password" type="password" placeholder="Nouveau mot de passe (optionnel)" />
                <button type="submit">Enregistrer</button>
              </form>
            </details>

            <form method="POST" action="/dashboard/users/<%= u.email %>?_method=DELETE" onsubmit="return confirm('Supprimer cet utilisateur ?')">
              <button type="submit">Supprimer</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>
</body>
</html>